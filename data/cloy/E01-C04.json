    {
      "id": 30,
      "start": 273.673,
      "end": 278.0,
      "ko": "나의 자랑스러운 아들 은동아."
    },
    {
      "id": 31,
      "start": 278.0,
      "end": 286.0,
      "ko": "몸 건강이 군 생활 잘하고 있느냐? 10년이란 길다면 길고 짧다면 짧은 세월."
    },
    {
      "id": 32,
      "start": 286.0,
      "end": 295.22,
      "ko": "10년 군복무 잘 마치고서 영웅 메달 가슴에 달고 고향으로 돌아오너라. 오마니.."
    },
    {
      "id": 33,
      "start": 310.41,
      "end": 314.85,
      "ko": "이거이 다 저 때문입니다.  아닙니다! 저 때문입니다!"
    },
    {
      "id": 34,
      "start": 314.85,
      "end": 319.303,
      "ko": "야. 야. 야. 지금 누구 때문 기딴거 따져서 뭐 하갔어?"
    },
    {
      "id": 35,
      "start": 319.303,
      "end": 326.0,
      "ko": "기리케 따지자믄 그, 지뢰를 밟는 바람에 최초에 그 에미나이를 놓친 뭐, 중대장 동지는 뭐, 책임이 없간?"
    },
    {
      "id": 36,
      "start": 326.0,
      "end": 334.34,
      "ko": "아니, 중대장 동지가 밟고 싶어 밟았갔냐, 어? 이기야."
    },
    {
      "id": 37,
      "start": 334.34,
      "end": 341.483,
      "ko": "그 계곡이 그, 유실 지뢰밭인 거, 응? 군대 막 들어온 은동이도 다 아는 사실인데 조심을 하셨갔디."
    },
    {
      "id": 38,
      "start": 341.483,
      "end": 344.379,
      "ko": "그런데 밟은 거를 어카네?"
    },
    {
      "id": 39,
      "start": 344.379,
      "end": 347.972,
      "ko": "표치수 동무는 술을 마셨어?"
    },
    {
      "id": 40,
      "start": 347.972,
      "end": 359.0,
      "ko": "예?  그, 술이라기보단 저, 약을 한 잔."
    },
    {
      "id": 41,
      "start": 359.0,
      "end": 364.493,
      "ko": "그, 재차 말하지만 우리가 지금 누구 잘 잘못을 따질 때가 아닙니다."
    },
    {
      "id": 42,
      "start": 364.493,
      "end": 367.0,
      "ko": "어서 빨리 그 에미나이를 잡아야지 않갔습니까?"
    },
    {
      "id": 43,
      "start": 367.0,
      "end": 373.018,
      "ko": "그 에미나이 보위부 애들한테 잡히려도 한 날이면 우리 모두는 다 끝장입니다."
    },
    {
      "id": 44,
      "start": 373.018,
      "end": 381.0,
      "ko": "끝장이믄?  선선한데(수용소를 가르키는 은어) 걸어 들어갔다가 누워서 나오갔디."
    },
    {
      "id": 45,
      "start": 381.0,
      "end": 387.0,
      "ko": "선선한데?  많이 봐줘도 생활제대(뷸명예제대)일 거고."
    },
    {
      "id": 46,
      "start": 387.0,
      "end": 389.075,
      "ko": "오마니."
    },
    {
      "id": 47,
      "start": 401.351,
      "end": 404.611,
      "ko": "중대교방 시간 다 됐어 가자.  예."
    },
    {
      "id": 48,
      "start": 404.611,
      "end": 408.35,
      "ko": "중대 차렷."
    },
    {
      "id": 49,
      "start": 408.35,
      "end": 415.61,
      "ko": "제5중대는 비무장지대 근무초소에 대한 인계를 완료했습니다. 5중대장 대위 리정혁"
    },
    {
      "id": 50,
      "start": 428.277,
      "end": 433.583,
      "ko": "긴데 그 무동력 비행체는 어케 우리 영토까지 넘어온 겁니까?"
    },
    {
      "id": 51,
      "start": 433.583,
      "end": 440.0,
      "ko": "흠, 무동력이니까 동력이 있으면 앞만 센 바람이 불어도 레이다가 다 걸러 냈갔지."
    },
    {
      "id": 52,
      "start": 440.0,
      "end": 447.006,
      "ko": "무동력은 열감지가 되지 않아서 눈으로 못 잡으면 놓치는 기야. 씁"
    },
    {
      "id": 53,
      "start": 447.006,
      "end": 455.541,
      "ko": "바람 타고 잘못 넘어온 거라믄 그 여성 동무도 참 놀랐깠습니다. 야"
    },
    {
      "id": 54,
      "start": 455.541,
      "end": 457.998,
      "ko": "나는 안 놀랐갔냐, 나는, 쯧."
    },
    {
      "id": 55,
      "start": 457.998,
      "end": 460.347,
      "ko": "들키기 전에 잡을 수 있갔디오?"
