  "subtitles": [
    {
      "id": 1,
      "start": 0.0,
      "end": 7.9,
      "ko": "보위 지도원한테 기케 시건방을 떨믄, 우리는 어케 되갔어?  뭐, 지야 헛가다 잡고 멋있어 보이갔디."
    },
    {
      "id": 2,
      "start": 7.9,
      "end": 16.871,
      "ko": "길티만 앞으로 보위국에서 아주 눈깔에 쌍심지를 켜고 우리 오중대를 지켜보지 않갔나 이기야."
    },
    {
      "id": 3,
      "start": 16.871,
      "end": 20.0,
      "ko": "긴데 중대장 동지는 왜 전초선까지 온 겁니까?"
    },
    {
      "id": 4,
      "start": 20.0,
      "end": 24.8,
      "ko": "아, 그, 평양서 왔으면 토대도 높갔구만 평양서 편하게 살면 되지 않갔습니까?"
    },
    {
      "id": 5,
      "start": 24.8,
      "end": 34.4,
      "ko": "기러니까 있는 놈들이 더 무섭다는 거야. 전후방을 훤히 꿰차서, 어? 장군님께 영원히 사랑받겠다는 심산는 아니갔어?"
    },
    {
      "id": 6,
      "start": 34.4,
      "end": 48.65,
      "ko": "아, 기렇구먼, 기래.. 자,자,자, 이 술이 최소 일천구백오십삼 년(1953년), 휴전 이전에 담가진 술이라는 것들만 똑똑히 알고들 마시라우, 응? 흐흐"
    },
    {
      "id": 7,
      "start": 48.65,
      "end": 55.788,
      "ko": "60년 먹은 뱀술 한 잔이면 허약(영양실조) 걸린 사람도 막 펄벌 난다 이기야. 어?"
    },
    {
      "id": 8,
      "start": 55.788,
      "end": 58.812,
      "ko": "이게, 이게, 술이 아니야. 약이야, 약."
    },
    {
      "id": 9,
      "start": 58.812,
      "end": 62.161,
      "ko": "기럼 저 약 한 잔만 하갔습니다."
    },
    {
      "id": 10,
      "start": 62.161,
      "end": 70.7,
      "ko": "기래, 기래, 기래.  자,자,자, 응, 기다리라우, 자, 자, 자, 자, 응?  긴대 근무 중에 이렇게 술 마셔도 됩니까?"
    },
    {
      "id": 11,
      "start": 70.7,
      "end": 80.381,
      "ko": "야, 두달을 주야간 근무 서지 않았네. 이제 해만뜨믄 교방(근무교체)인데 별일 있갔어? 하하하하."
    },
    {
      "id": 12,
      "start": 80.381,
      "end": 87.8,
      "ko": "중대장 동지. 한참 찾았습니다."
    },
    {
      "id": 13,
      "start": 87.8,
      "end": 92.7,
      "ko": "어서 중대원들에게 알리라. 우리 위수구역 내에 거동 수상자가 발견되는 즉시 체포할 것."
    },
    {
      "id": 14,
      "start": 92.7,
      "end": 97.5,
      "ko": "의거 입북자입니까? 아니면 간첩?"
    },
    {
      "id": 15,
      "start": 97.5,
      "end": 104.259,
      "ko": "단순 사고로 흘러들어 온 남조선 여성이다. 쏘지 말고 체포하라. 명령하달. 예!"
    },
    {
      "id": 16,
      "start": 104.259,
      "end": 112.7,
      "ko": "여기는 비둘기. 여기는 비둘기. 뻐꾸기 나오라. 여기는 비둘기. 여기는 비둘기. 뻐꾸기 나오라."
    },
    {
      "id": 17,
      "start": 112.7,
      "end": 120.7,
      "ko": "누가 뻐꾸기를 찾네. 여기는 비둘기. 뻐꾸기 나오라."
    },
    {
      "id": 18,
      "start": 120.7,
      "end": 123.729,
      "ko": "무전은 다 쳤습니다."
    },
    {
      "id": 19,
      "start": 129.509,
      "end": 140.415,
      "ko": "거기 서, 이 무장간첩아! 어떡하지? 에이, 씨. 이 남조선 에미나이. 이리 오라! 이리! 야 이리 오라!"
    },
    {
      "id": 20,
      "start": 140.415,
      "end": 147.499,
      "ko": "목숨만은 살려 주갔어. 야. 저. 저, 저.. 저 미친 에미나이 저기를 왜..."
    },
    {
      "id": 21,
      "start": 147.499,
      "end": 150.593,
      "ko": "이것들이 여기까지."
    },
    {
      "id": 22,
      "start": 150.593,
      "end": 159.142,
      "ko": "아니야. 가지 말라. 거기는 너희 나라가 아니고야! 이리 오라, 이리!"
    },
    {
      "id": 23,
      "start": 159.142,
      "end": 163.406,
      "ko": "뭐? 뭐래는 거야?"
    },
    {
      "id": 24,
      "start": 163.406,
      "end": 173.497,
      "ko": "거기 가면 우리 다 뒤지는 기야! 가지 말라! 거기 아니라고! 미친, 야, 이 에미나이야!"
    },
    {
      "id": 25,
      "start": 178.407,
      "end": 184.185,
      "ko": "바보 아니네? 저길 와 넘어가네?"
    },
    {
      "id": 26,
      "start": 184.185,
      "end": 192.0,
      "ko": "어, 어캅니까? 초소에 무전부터 치라."
    },
    {
      "id": 27,
      "start": 192.0,
      "end": 201.0,
      "ko": "여기는 뻐꾸기, 갈매기 나오라. 여기는  뻐꾸기, 갈매기 나오라. 갈매기, 야, 갈매기."
    },
    {
      "id": 28,
      "start": 201.0,
      "end": 215.673,
      "ko": "사랑하는   사람들은, 만나는 거야. 아무리 먼 길을 떠나도, 결국, 돌아오는 거야. 아유."
    },
    {
      "id": 29,
      "start": 224.299,
      "end": 232.579,
      "ko": "야. 붙이라. 목걸이 붙이라. 야."
